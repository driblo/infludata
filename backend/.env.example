APP_NAME=infludata
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database (Postgres + TimescaleDB) -----------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=infludata
DB_USERNAME=infludata
DB_PASSWORD=infludata

# --- Cache / queue / session (Redis) -------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (mailpit in dev) ------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@infludata.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3-compatible object storage (MinIO in dev) --------------------------
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniominio
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=infludata
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Sanctum --------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1
SANCTUM_TOKEN_EXPIRATION=43200

# --- Sentry (optional) ----------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Phyllo (unified social aggregator) -----------------------------------
PHYLLO_BASE_URL=https://api.sandbox.getphyllo.com
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
PHYLLO_WEBHOOK_SECRET=
PHYLLO_ENV=sandbox

# --- Direct platform credentials (supplement) -----------------------------
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=

X_BEARER_TOKEN=
X_MAX_DAILY_USD=5

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Feature flags --------------------------------------------------------
FEATURE_NETWORK_YOUTUBE=true
FEATURE_NETWORK_INSTAGRAM=true
FEATURE_NETWORK_TIKTOK=false
FEATURE_NETWORK_X=false
FEATURE_NETWORK_FACEBOOK=false
